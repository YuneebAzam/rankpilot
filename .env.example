# --- Database ---
# Default: SQLite (zero-config, great for local/demo).
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production), set the provider to "postgresql" in
# prisma/schema.prisma and use a URL like:
#   postgresql://user:password@localhost:5432/rankpilot?schema=public
# or a free Neon branch: https://neon.tech

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"
# Base URL of the app
AUTH_URL="http://localhost:3000"

# --- (Phase 3+) Anthropic Claude API ---
# ANTHROPIC_API_KEY="sk-ant-..."

# --- (Phase 5) Stripe ---
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
